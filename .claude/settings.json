{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "python3 .claude/hooks/post-tool-use.py",
            "timeout": 10,
            "type": "command"
          },
          {
            "command": "python3 .claude/hooks/session-logger.py",
            "timeout": 3,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "python3 .claude/hooks/block-bad-commands.py",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "python3 .claude/hooks/guard-file-writes.py",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "python3 .claude/hooks/session-start.py",
            "statusMessage": "Loading Notion brain...",
            "timeout": 15,
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "python3 .claude/hooks/stop-notion.py",
            "statusMessage": "Finishing session...",
            "timeout": 30,
            "type": "command"
          },
          {
            "command": "python3 .claude/hooks/stop.py",
            "timeout": 30,
            "type": "command"
          },
          {
            "command": "true",
            "statusMessage": "Brain indexer disabled (run manually: python3 .claude/hooks/varys-brain-watcher.py)",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "python3 .claude/hooks/session-logger.py",
            "timeout": 3,
            "type": "command"
          },
          {
            "command": "python3 .claude/hooks/varys-task-interceptor.py",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "mcpServers": {
    "canva": {
      "description": "Canva Pro design creation via OAuth",
      "type": "http",
      "url": "https://mcp.canva.com/mcp"
    },
    "mempalace": {
      "args": [
        "serve",
        "--palace",
        "mempalace"
      ],
      "command": "mempalace",
      "description": "Semantic memory — kept as fallback"
    },
    "notion": {
      "command": "/home/shoaib/.nvm/versions/node/v24.14.0/bin/notion-mcp-server",
      "env": {
        "OPENAPI_MCP_HEADERS": "{\"Authorization\": \"Bearer ${NOTION_API_KEY}\", \"Notion-Version\": \"2022-06-28\"}"
      }
    }
  },
  "model": "sonnet"
}