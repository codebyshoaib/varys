# Secret token files — never commit these
.claude/hooks/.notion
.claude/hooks/.slack
.claude/hooks/.linkedin
.claude/hooks/.axiom

# User session data — personal to each install
vault/logs/*
!vault/logs/.gitkeep
vault/notion-map.md
# Beads data files — private, never push to public repo
.beads/issues.jsonl
.beads/decisions.jsonl
.beads/evolution.jsonl
.beads/status.jsonl
.beads/metadata.json
.beads/failures.jsonl

# Python
*.pyc
__pycache__/

# OS
.DS_Store

# Repo symlinks — these point to sibling repos, not tracked here
repos/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Re-include .beads/ so config/hooks files (config.yaml, .gitignore, hooks/) are trackable.
# Data files (*.jsonl, metadata.json) are excluded above — they are private.
!.beads/
