# Secret token files — never commit these
.claude/hooks/.notion
.claude/hooks/.slack
.claude/hooks/.linkedin
.claude/hooks/.axiom

# User session data — personal to each install
vault/logs/*
!vault/logs/.gitkeep
vault/notion-map.md
.beads/failures.jsonl

# Python
*.pyc
__pycache__/

# OS
.DS_Store

# Repo symlinks — these point to sibling repos, not tracked here
repos/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# bd git-sync: ~/.gitignore_global ignores .beads/ entirely, which blocks
# bd's git-based bead sync (sync.remote=git) — its `git add .beads/issues.jsonl`
# fails on every write. Re-include the dir so committed bead files are trackable;
# .beads/.gitignore still excludes per-machine/runtime files, and the line above
# still excludes per-machine/runtime files.
!.beads/
